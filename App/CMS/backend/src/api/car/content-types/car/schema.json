{
  "kind": "collectionType",
  "collectionName": "cars",
  "info": {
    "singularName": "car",
    "pluralName": "cars",
    "displayName": "Car"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "Name": {
      "type": "string",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Description": {
      "type": "text",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Brand": {
      "type": "string",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "Trim": {
      "type": "string",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },

    "Price":       { "type": "float" },
    "Image":       { "type": "media", "multiple": true, "allowedTypes": ["images"] },
    "Year":        { "type": "integer" },
    "Kilometers":  { "type": "float" },
    "Condition":   { "type": "enumeration", "enum": ["New", "Used"] },
    "PaintParts":  { "type": "string" },
    "Fuel":        { "type": "string" },
    "ImportCountry": { "type": "string" },
    "Plate":       { "type": "string" },
    "EngineSize":  { "type": "float" },
    "Cylinders":   { "type": "integer" },
    "Transmission": {
      "type": "enumeration",
      "enum": ["Automatic", "Manual"]
    },
    "SeatNumber":  { "type": "integer" },
    "SeatMaterial": { "type": "string" },
    "Color":       { "type": "string" }
  }
}