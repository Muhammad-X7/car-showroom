{
  "kind": "collectionType",
  "collectionName": "cars",
  "info": {
    "singularName": "car",
    "pluralName": "cars",
    "displayName": "Car"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string"
    },
    "Price": {
      "type": "float"
    },
    "Image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Brand": {
      "type": "string"
    },
    "Kilometers": {
      "type": "float"
    },
    "Description": {
      "type": "text"
    },
    "Trim": {
      "type": "string"
    },
    "Condition": {
      "type": "enumeration",
      "enum": [
        "New",
        "Used"
      ]
    },
    "PaintParts": {
      "type": "string"
    },
    "Fuel": {
      "type": "string"
    },
    "ImportCountry": {
      "type": "string"
    },
    "Plate": {
      "type": "string"
    },
    "EngineSize": {
      "type": "float"
    },
    "Cylinders": {
      "type": "integer"
    },
    "Transmission": {
      "type": "enumeration",
      "enum": [
        "Automatic",
        "Manual"
      ]
    },
    "SeatNumber": {
      "type": "integer"
    },
    "SeatMaterial": {
      "type": "string"
    },
    "Color": {
      "type": "string"
    }
  }
}